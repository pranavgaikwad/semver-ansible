# Stage 1: Go builder — kantra, java-external-provider, and kantra release assets
FROM registry.access.redhat.com/ubi9/go-toolset AS go-builder

ARG KANTRA_VERSION=v0.9.2-rc.1
ARG KANTRA_REPO=https://github.com/konveyor/kantra.git
ARG ANALYZER_LSP_REPO=https://github.com/konveyor/analyzer-lsp.git

USER root
RUN dnf install -y unzip && dnf clean all

# Download kantra release for assets (jdtls, rulesets, static-report, etc.)
RUN curl -fSL -o /tmp/kantra.zip \
    "https://github.com/konveyor/kantra/releases/download/${KANTRA_VERSION}/kantra.linux.amd64.zip" \
    && mkdir -p /kantra-assets && unzip /tmp/kantra.zip -d /kantra-assets/ \
    && rm /tmp/kantra.zip

# Build kantra binary from source (replaces release binary)
RUN git clone --depth 1 "$KANTRA_REPO" /src/kantra
WORKDIR /src/kantra
RUN CGO_ENABLED=0 go build -o /kantra-assets/kantra main.go

# Build java-external-provider
RUN git clone --depth 1 "$ANALYZER_LSP_REPO" /src/analyzer-lsp
WORKDIR /src/analyzer-lsp/external-providers/java-external-provider
RUN CGO_ENABLED=0 go build -o /kantra-assets/java-external-provider main.go

# Trim kantra assets — remove Java-only files and empty out the huge maven-index.txt
RUN : > /kantra-assets/maven-index.txt \
    && rm -rf /kantra-assets/rulesets \
    && mkdir -p /kantra-assets/rulesets


# Stage 2: Rust builder — semver-analyzer, frontend-analyzer-provider, fix-engine-cli
FROM registry.access.redhat.com/ubi9/ubi AS rust-builder

ARG SEMVER_REPO=https://github.com/shawn-hurley/semver-analyzer.git
ARG KONVEYOR_CORE_REPO=https://github.com/shawn-hurley/konveyor-core.git
ARG FAP_REPO=https://github.com/shawn-hurley/frontend-analyzer-provider.git
ARG FIX_ENGINE_REPO=https://github.com/shawn-hurley/fix-engine.git

RUN dnf install -y gcc gcc-c++ make openssl-devel pkg-config git && dnf clean all

# Install Rust via rustup
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
ENV PATH="/root/.cargo/bin:${PATH}"

# Clone repos (konveyor-core must be sibling to semver-analyzer)
WORKDIR /src
RUN git clone "$KONVEYOR_CORE_REPO" \
    && git clone "$SEMVER_REPO" \
    && git clone "$FAP_REPO" \
    && git clone "$FIX_ENGINE_REPO"

# Build semver-analyzer
WORKDIR /src/semver-analyzer
RUN cargo build --release

# Build frontend-analyzer-provider
WORKDIR /src/frontend-analyzer-provider
RUN cargo build --release

# Build fix-engine-cli
WORKDIR /src/fix-engine
RUN cargo build --release

# Strip debug symbols
RUN strip \
    /src/semver-analyzer/target/release/semver-analyzer \
    /src/frontend-analyzer-provider/target/release/frontend-analyzer-provider \
    /src/fix-engine/target/release/fix-engine-cli


# Stage 3: Rule generation
FROM registry.access.redhat.com/ubi9/nodejs-20 AS rule-generator

ARG PF_REACT_FROM=v5.4.0
ARG PF_REACT_TO=v6.4.1
ARG PF_DEP_FROM=v5.4.0
ARG PF_DEP_TO=v6.4.0
ARG TOKEN_MAPPINGS_URL=https://raw.githubusercontent.com/shawn-hurley/semver-analyzer/refs/heads/main/hack/integration/patternfly-token-mappings.yaml

USER root
RUN dnf install -y git && dnf clean all
RUN npm install -g corepack && corepack enable

COPY --from=rust-builder /src/semver-analyzer/target/release/semver-analyzer /usr/local/bin/

# Clone PatternFly repos
WORKDIR /src
RUN git clone https://github.com/patternfly/patternfly-react.git \
    && git clone https://github.com/patternfly/patternfly.git

# Download token mappings
RUN curl -fSL -o /src/patternfly-token-mappings.yaml "$TOKEN_MAPPINGS_URL"

# Generate semver report (YARN_ENABLE_SCRIPTS=false skips native module builds that fail in containers)
ENV YARN_ENABLE_SCRIPTS=false
RUN semver-analyzer analyze typescript \
    --repo /src/patternfly-react \
    --from "$PF_REACT_FROM" --to "$PF_REACT_TO" \
    --dep-repo /src/patternfly \
    --dep-from "$PF_DEP_FROM" --dep-to "$PF_DEP_TO" \
    --dep-build-command "yarn install && npx gulp buildPatternfly" \
    --build-command "corepack yarn build" \
    --no-llm \
    -o /src/semver_report.json

# Generate Konveyor rules
RUN mkdir -p /rules/semver_rules \
    && semver-analyzer konveyor typescript \
    --from-report /src/semver_report.json \
    --output-dir /rules/semver_rules \
    --rename-patterns /src/patternfly-token-mappings.yaml


# Stage 4: Runtime image
FROM registry.access.redhat.com/ubi9/ubi-minimal

# System dependencies
RUN microdnf install -y --nodocs \
    bash \
    java-21-openjdk-devel \
    maven \
    python3 \
    python3-pyyaml \
    git \
    which \
    procps-ng \
    lsof \
    bzip2 \
    tar \
    libgomp \
    && microdnf clean all

# yq
ARG TARGETARCH=amd64
RUN curl -fsSL "https://github.com/mikefarah/yq/releases/latest/download/yq_linux_${TARGETARCH}" \
    -o /usr/local/bin/yq && chmod +x /usr/local/bin/yq

# Goose CLI
ENV CONFIGURE=false
RUN curl -fsSL \
    https://github.com/aaif-goose/goose/releases/download/stable/download_cli.sh | bash
ENV CONFIGURE=

# Environment
ENV JAVA_HOME=/usr/lib/jvm/java-21-openjdk
ENV KANTRA_DIR=/opt/patternfly-tools/.kantra
ENV PATH="${JAVA_HOME}/bin:/root/.local/bin:${PATH}"

# Git config for auto-commit step
RUN git config --system safe.directory '*' \
    && git config --system user.name "PatternFly Migration" \
    && git config --system user.email "pf-migration@localhost"

WORKDIR /opt/patternfly-tools

# Kantra assets + Go binaries
COPY --from=go-builder /kantra-assets/ .kantra/

# Rust binaries
RUN mkdir -p bin
COPY --from=rust-builder /src/semver-analyzer/target/release/semver-analyzer bin/
COPY --from=rust-builder /src/frontend-analyzer-provider/target/release/frontend-analyzer-provider bin/
COPY --from=rust-builder /src/fix-engine/target/release/fix-engine-cli bin/

# Rules and fix strategies
COPY --from=rule-generator /rules/ rules/
COPY --from=rule-generator /src/patternfly-token-mappings.yaml .

# FAP bundled strategies
COPY --from=rust-builder /src/frontend-analyzer-provider/rules/patternfly-v5-to-v6/fix-strategies.json rules/fix-guidance/

# Default goose config (can be overridden by mounting ~/.config/goose)
RUN mkdir -p /root/.config/goose
COPY goose-config.yaml /root/.config/goose/config.yaml

# run.sh and prompt
COPY run.sh prompt.md eval_prompt.md* ./
RUN chmod +x run.sh bin/* .kantra/kantra .kantra/java-external-provider

VOLUME ["/workspace"]

ENTRYPOINT ["/opt/patternfly-tools/run.sh"]
CMD ["--help"]
